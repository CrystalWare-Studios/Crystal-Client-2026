# build/release notes. Never publish this folder.
Dev Tools/

# Superseded/duplicate source, kept locally for reference but not published
Legacy(oldversion)/
backup_original_source/
Readme Files/

# Replit hosting artifacts - not used by the actual app, nothing to publish
.replit
pyproject.toml
replit.md
.local/
attached_assets/

