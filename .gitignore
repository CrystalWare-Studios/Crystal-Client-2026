# Encrypted/obfuscated build output (built by Dev Tools/encrypt_for_*.py, not source)
dist_encrypted/*
!dist_encrypted/settings_template.json
!dist_encrypted/version.txt
build_encrypted/
obfuscated_source/

# Maintainer-only tooling - contains the Patreon license signing secret
